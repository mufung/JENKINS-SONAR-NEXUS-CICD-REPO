pipeline{

    agent any

    stages{

        stage("continuous download") {

            steps{
                git branch: 'main', url: 'https://github.com/mufung/JENKINS-SONAR-NEXUS-CICD-REPO.git'
            }
        }
        stage("unit test") {

            steps{
                sh'mvn test'
            }
        }
        stage("integration test"){

            steps{
                sh'mvn verify -DskipUnitTests'
            }
        }
        stage("continuous build") {

            steps{
                sh'mvn clean install'
            }
        }
        stage("static test analysis") {

            steps{

                script{
                     withSonarQubeEnv(credentialsId: 'sonar-Auth') {
                        sh 'mvn clean package sonar:sonar'
                     }
                }
            }
        }
        stage("quality gate analysis") {

            steps{

                script{
                  waitForQualityGate abortPipeline: false, credentialsId: 'sonar-Auth'  
                }
            }
        }
        stage("uplaod artifact to nexus"){
    steps{
        script{
            nexusArtifactUploader artifacts: [[artifactId: 'springboot', classifier: '', file: 'target/springboot-1.0.0.jar', type: 'jar']], credentialsId: 'nexus-auth', groupId: 'com.example', nexusUrl: '98.89.20.120:8081', nexusVersion: 'nexus3', protocol: 'http', repository: 'jenks-project', version: '1.0.0'
        }
    }
}
        stage("Docker Build"){

            steps{

                script{
                    sh 'docker build -t myuber .'
                    sh 'docker tag myuber:latest mufungdockeraccount/jenks-project:my-first-project-image11'
                }
            }
        }
        stage("push image to dockerhub"){

            steps{

                script{
                    withCredentials([string(credentialsId: 'docker_auth', variable: 'docker_cred')]) {
                        sh 'docker login -u mufungdockeraccount -p ${docker_cred}'
                        sh 'docker tag myuber:latest mufungdockeraccount/jenks-project:my-first-project-image11'
                        sh 'docker push mufungdockeraccount/jenks-project:my-first-project-image11'
                    }

                }
            }
        }
    }
}